{
  "info": {
    "name": "RentNest API",
    "description": "RentNest - Rental Property Marketplace Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newtenant@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"New Tenant\",\n  \"role\": \"TENANT\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Register Landlord",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newlandlord@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"New Landlord\",\n  \"role\": \"LANDLORD\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@rentnest.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant@rentnest.com\",\n  \"password\": \"tenant123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Landlord",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"landlord@rentnest.com\",\n  \"password\": \"landlord123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Properties (Public)",
      "item": [
        {
          "name": "Get All Properties",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/properties?location=Gulshan&minPrice=10000&maxPrice=100000&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["properties"],
              "query": [
                { "key": "location", "value": "Gulshan" },
                { "key": "minPrice", "value": "10000" },
                { "key": "maxPrice", "value": "100000" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Property by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties/:id"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Landlord",
      "item": [
        {
          "name": "Create Property",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cozy Studio in Banani\",\n  \"description\": \"A fully furnished studio apartment with modern amenities and great location near restaurants and shops.\",\n  \"location\": \"Banani\",\n  \"address\": \"Road 11, Banani, Dhaka\",\n  \"price\": 25000,\n  \"bedrooms\": 1,\n  \"bathrooms\": 1,\n  \"area\": 600,\n  \"amenities\": [\"WiFi\", \"AC\", \"Furnished\"],\n  \"images\": [\"https://images.unsplash.com/photo-1502672260266-1c1ef2d93688\"],\n  \"categoryId\": \"CATEGORY_ID_HERE\"\n}"
            },
            "url": "{{baseUrl}}/landlord/properties"
          }
        },
        {
          "name": "Get My Properties",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/landlord/properties"
          }
        },
        {
          "name": "Update Property",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 48000,\n  \"status\": \"AVAILABLE\"\n}"
            },
            "url": "{{baseUrl}}/landlord/properties/:id"
          }
        },
        {
          "name": "Delete Property",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/landlord/properties/:id"
          }
        },
        {
          "name": "Get Rental Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/landlord/requests"
          }
        },
        {
          "name": "Approve/Reject Request",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\"\n}"
            },
            "url": "{{baseUrl}}/landlord/requests/:id"
          }
        }
      ]
    },
    {
      "name": "Rentals (Tenant)",
      "item": [
        {
          "name": "Submit Rental Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"PROPERTY_ID_HERE\",\n  \"startDate\": \"2026-08-01T00:00:00.000Z\",\n  \"endDate\": \"2027-07-31T00:00:00.000Z\",\n  \"message\": \"I would like to rent this property.\"\n}"
            },
            "url": "{{baseUrl}}/rentals"
          }
        },
        {
          "name": "Get My Rentals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/rentals"
          }
        },
        {
          "name": "Get Rental by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/rentals/:id"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalRequestId\": \"RENTAL_ID_HERE\",\n  \"rating\": 5,\n  \"comment\": \"Great property, highly recommended!\"\n}"
            },
            "url": "{{baseUrl}}/reviews"
          }
        },
        {
          "name": "Get Property Reviews",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reviews/property/:propertyId"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Ban/Unban User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"BANNED\"\n}"
            },
            "url": "{{baseUrl}}/admin/users/:id"
          }
        },
        {
          "name": "Get All Properties",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/properties"
          }
        },
        {
          "name": "Get All Rentals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/rentals"
          }
        }
      ]
    },
    {
      "name": "Payments (Stripe)",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalRequestId\": \"RENTAL_ID_HERE\",\n  \"provider\": \"STRIPE\"\n}"
            },
            "url": "{{baseUrl}}/payments/create"
          }
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"PAYMENT_ID_HERE\",\n  \"transactionId\": \"pi_STRIPE_INTENT_ID\"\n}"
            },
            "url": "{{baseUrl}}/payments/confirm"
          }
        },
        {
          "name": "Get Payment History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Get Payment By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/payments/PAYMENT_ID_HERE"
          }
        }
      ]
    }
  ]
}
